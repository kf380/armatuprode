generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  authId       String   @unique
  email        String   @unique
  name         String
  avatar       String   @default("🎮")
  country      String   @default("🇦🇷")
  countryName  String   @default("Argentina")
  xp           Int      @default(0)
  coins        Int      @default(100)
  referralCode String?  @unique
  referredById String?
  createdAt    DateTime @default(now())

  referredBy User?  @relation("UserReferrals", fields: [referredById], references: [id])
  referrals  User[] @relation("UserReferrals")

  predictions        Prediction[]
  memberships        GroupMember[]
  contributions      PoolContribution[]
  xpEvents           XpEvent[]
  notifications      Notification[]
  activityEvents     ActivityEvent[]
  badges             UserBadge[]
  boosters           UserBooster[]
  coinTransactions   CoinTransaction[]
  pushSubscriptions  PushSubscription[]
  wallet             Wallet?
  boosterActivations BoosterActivation[]
  chatMessages       ChatMessage[]
  chatMutes          ChatMute[]
  paymentOrders      PaymentOrder[]
}

model Tournament {
  id        String          @id @default(uuid())
  name      String
  type      TournamentType  @default(WORLD_CUP)
  phase     TournamentPhase @default(GROUP_STAGE)
  startDate DateTime
  endDate   DateTime
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())

  matches Match[]
  groups  Group[]
}

enum TournamentType {
  WORLD_CUP
  COPA_AMERICA
  CHAMPIONS_LEAGUE
  LIBERTADORES
  LEAGUE
  OTHER
}

enum TournamentPhase {
  GROUP_STAGE
  ROUND_OF_16
  QUARTER_FINALS
  SEMI_FINALS
  FINAL
}

model Match {
  id           String          @id @default(uuid())
  tournamentId String
  teamACode    String
  teamAName    String
  teamAFlag    String
  teamBCode    String
  teamBName    String
  teamBFlag    String
  matchDate    DateTime
  matchGroup   String?
  phase        TournamentPhase @default(GROUP_STAGE)
  status       MatchStatus     @default(UPCOMING)
  scoreA       Int?
  scoreB       Int?
  minute       Int?
  period       String?
  reminderSent Boolean         @default(false)

  qualifiedTeam String?

  tournament         Tournament          @relation(fields: [tournamentId], references: [id])
  predictions        Prediction[]
  xpEvents           XpEvent[]
  boosterActivations BoosterActivation[]

  @@index([tournamentId, status])
  @@index([matchDate])
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

model Prediction {
  id                 String   @id @default(uuid())
  userId             String
  matchId            String
  scoreA             Int
  scoreB             Int
  points             Int      @default(0)
  boosterApplied     String?
  predictedQualifier String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
  @@index([userId])
}

model Group {
  id               String   @id @default(uuid())
  name             String
  emoji            String   @default("🏆")
  tournamentId     String
  createdById      String
  inviteCode       String   @unique @default(uuid())
  hasPool          Boolean  @default(false)
  entryFee         Int      @default(0)
  poolDistribution Int[]    @default([50, 30, 20])
  currency         String   @default("ARS")
  createdAt        DateTime @default(now())

  tournament     Tournament         @relation(fields: [tournamentId], references: [id])
  members        GroupMember[]
  contributions  PoolContribution[]
  activityEvents ActivityEvent[]
  chatMessages   ChatMessage[]
  chatMutes      ChatMute[]

  @@index([inviteCode])
  @@index([tournamentId])
}

model GroupMember {
  id       String    @id @default(uuid())
  userId   String
  groupId  String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

enum GroupRole {
  ADMIN
  MEMBER
}

model PoolContribution {
  id      String    @id @default(uuid())
  userId  String
  groupId String
  amount  Int
  paid    Boolean   @default(false)
  paidAt  DateTime?

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

model XpEvent {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  matchId   String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  match Match? @relation(fields: [matchId], references: [id])

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  icon      String   @default("🔔")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

model ActivityEvent {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  type      String
  text      String
  icon      String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt])
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserBooster {
  id       String @id @default(uuid())
  userId   String
  type     String
  quantity Int    @default(1)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model CoinTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// --- Wallet & Economy ---

enum WalletLotSource {
  PREDICTION
  WINNER
  EXACT
  STREAK
  MATCHDAY
  REFERRAL
  PURCHASE
  MIGRATION
  ADMIN
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  EXPIRY
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  lots         WalletLot[]
  transactions WalletTransaction[]
}

model WalletLot {
  id        String          @id @default(uuid())
  walletId  String
  source    WalletLotSource
  amount    Int
  remaining Int
  expiresAt DateTime
  createdAt DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, expiresAt])
}

model WalletTransaction {
  id             String                @id @default(uuid())
  walletId       String
  type           WalletTransactionType
  amount         Int
  source         String?
  reason         String
  idempotencyKey String?               @unique
  metadata       Json?
  createdAt      DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
}

model BoosterActivation {
  id        String   @id @default(uuid())
  userId    String
  matchId   String
  type      String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

// --- Group Chat ---

enum ChatMessageType {
  TEXT
  STICKER
  SYSTEM
}

model ChatMessage {
  id         String          @id @default(uuid())
  groupId    String
  userId     String?
  type       ChatMessageType @default(TEXT)
  content    String
  stickerKey String?
  deleted    Boolean         @default(false)
  createdAt  DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt])
}

model ChatMute {
  id         String   @id @default(uuid())
  groupId    String
  userId     String
  mutedUntil DateTime
  createdAt  DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

// --- Payments ---

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum PaymentType {
  COIN_PACK
  POOL_ENTRY
}

model PaymentOrder {
  id           String        @id @default(uuid())
  userId       String
  type         PaymentType
  status       PaymentStatus @default(PENDING)
  amount       Int
  description  String
  metadata     Json?
  externalId   String?       @unique
  preferenceId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}
