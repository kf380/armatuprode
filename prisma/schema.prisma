generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  authId       String   @unique
  email        String   @unique
  name         String
  avatar       String   @default("🎮")
  country      String   @default("🇦🇷")
  countryName  String   @default("Argentina")
  xp           Int      @default(0)
  coins        Int      @default(100)
  referralCode String?  @unique
  referredById String?
  createdAt    DateTime @default(now())

  referredBy User?  @relation("UserReferrals", fields: [referredById], references: [id])
  referrals  User[] @relation("UserReferrals")

  predictions        Prediction[]
  memberships        GroupMember[]
  contributions      PoolContribution[]
  xpEvents           XpEvent[]
  notifications      Notification[]
  activityEvents     ActivityEvent[]
  badges             UserBadge[]
  boosters           UserBooster[]
  coinTransactions   CoinTransaction[]
  pushSubscriptions  PushSubscription[]
  wallet             Wallet?
  boosterActivations BoosterActivation[]
  chatMessages       ChatMessage[]
  chatReactions      ChatReaction[]
  chatMutes          ChatMute[]
  paymentOrders      PaymentOrder[]
  premiumMemberships PremiumMembership[]
}

model Tournament {
  id            String          @id @default(uuid())
  slug          String?         @unique
  name          String
  year          Int?
  hostCountries String[]        @default([])
  type          TournamentType  @default(WORLD_CUP)
  phase         TournamentPhase @default(GROUP_STAGE)
  startDate     DateTime
  endDate       DateTime
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())

  matches            Match[]
  groups             Group[]
  teams              Team[]
  premiumMemberships PremiumMembership[]
}

enum TournamentType {
  WORLD_CUP
  COPA_AMERICA
  CHAMPIONS_LEAGUE
  LIBERTADORES
  LEAGUE
  OTHER
}

enum TournamentPhase {
  GROUP_STAGE
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINALS
  SEMI_FINALS
  THIRD_PLACE
  FINAL
}

model Match {
  id                   String          @id @default(uuid())
  tournamentId         String
  officialMatchNumber  Int?
  teamACode            String
  teamAName            String
  teamAFlag            String
  teamBCode            String
  teamBName            String
  teamBFlag            String
  matchDate            DateTime
  matchGroup           String?
  phase                TournamentPhase @default(GROUP_STAGE)
  status               MatchStatus     @default(UPCOMING)
  scoreA               Int?
  scoreB               Int?
  minute               Int?
  period               String?
  reminderSent         Boolean         @default(false)
  venue                String?
  city                 String?
  country              String?
  source               String?

  // Scoring lock — set atomically by /finish to prevent concurrent scoring.
  scoringLockedAt DateTime?

  qualifiedTeam String?

  tournament         Tournament          @relation(fields: [tournamentId], references: [id])
  predictions        Prediction[]
  xpEvents           XpEvent[]
  boosterActivations BoosterActivation[]

  @@unique([tournamentId, officialMatchNumber])
  @@index([tournamentId, status])
  @@index([tournamentId, phase])
  @@index([tournamentId, matchGroup])
  @@index([matchDate])
  @@index([status, matchDate])
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

model Prediction {
  id                 String   @id @default(uuid())
  userId             String
  matchId            String
  scoreA             Int
  scoreB             Int
  points             Int      @default(0)
  boosterApplied     String?
  predictedQualifier String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
  @@index([userId])
}

model Group {
  id               String   @id @default(uuid())
  name             String
  emoji            String   @default("🏆")
  tournamentId     String
  createdById      String
  inviteCode       String   @unique @default(uuid())
  hasPool          Boolean  @default(false)
  entryFee         Int      @default(0)
  poolDistribution Int[]    @default([50, 30, 20])
  currency         String   @default("ARS")
  createdAt        DateTime @default(now())

  // --- B2B evolution ---
  type                  GroupType             @default(PERSONAL)
  organizationId        String?
  planType              PlanType              @default(FREE)
  status                GroupStatus           @default(ACTIVE)
  isPremium             Boolean               @default(false)
  participantLimit      Int                   @default(10)
  prizeType             PrizeType             @default(NONE)
  prizeDescription      String?
  rulesDescription      String?
  publicJoinEnabled     Boolean               @default(false)
  brandingConfig        Json?
  billingStatus         String?
  paymentResponsibility PaymentResponsibility @default(NONE)

  // --- Phase 2: Manual Pool ---
  // Default NONE keeps the legacy behavior: organizer pays plan, no pool.
  // MANUAL_POOL means the organizer declares an entry amount and the platform
  // displays the pool informationally; the platform never custodies money.
  moneyMode             MoneyMode  @default(NONE)
  declaredPoolEntry     Int?       // ARS amount per player (informative)
  declaredPoolCurrency  String?    @default("ARS")
  declaredPoolUpdatedAt DateTime?

  // When true (default), members can see each other's predictions before
  // kickoff. When false, others' predictions stay hidden until the match
  // starts — adds suspense for "Vs entre amigos" reveal.
  revealPredictionsBeforeKickoff Boolean @default(true)

  tournament      Tournament            @relation(fields: [tournamentId], references: [id])
  organization    Organization?         @relation(fields: [organizationId], references: [id])
  members         GroupMember[]
  contributions   PoolContribution[]
  poolTrackings   PoolPaymentTracking[]
  activityEvents  ActivityEvent[]
  chatMessages    ChatMessage[]
  chatMutes       ChatMute[]

  @@index([inviteCode])
  @@index([tournamentId])
  @@index([organizationId])
  @@index([status])
  @@index([type, planType])
}

enum GroupType {
  PERSONAL
  ORGANIZATION
}

/// MoneyMode controls how money flows around a Group.
///   NONE          → organizer pays plan; players join free; manual prize.
///                   This is the default and the only mode active until
///                   Phase 2 ships.
///   MANUAL_POOL   → organizer declares an entry amount + suggested pool.
///                   The platform shows the pool informationally and tracks
///                   who paid (organizer-marked), but NEVER custodies or
///                   distributes the money. Pricing for the organizer becomes
///                   USD 5 base + 7% of declared pool (capped USD 400).
///   AUTOMATED_POOL → reserved for Phase 4 (regulated jurisdictions only).
///                    NOT enabled. Requires legal sign-off + KYC + license.
enum MoneyMode {
  NONE
  MANUAL_POOL
  AUTOMATED_POOL
}

enum PlanType {
  FREE
  PERSONAL_PLUS
  COMMUNITY
  BUSINESS
  WHITE_LABEL
}

enum GroupStatus {
  DRAFT
  PENDING_PAYMENT
  ACTIVE
  PAUSED
  FINISHED
  CANCELLED
  PAYMENT_FAILED
  PAYMENT_REVERSED
}

enum PaymentResponsibility {
  NONE
  ORGANIZER
  COMPANY
}

enum PrizeType {
  NONE
  MANUAL_FIXED
  SPONSOR
}

model Organization {
  id            String       @id @default(uuid())
  slug          String       @unique
  name          String
  logoUrl       String?
  description   String?
  ownerId       String
  plan          PlanType     @default(FREE)
  billingStatus String?
  maxPlayers    Int          @default(10)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  members OrganizationMember[]
  groups  Group[]

  @@index([ownerId])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           OrgMemberRole @default(PLAYER)
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
}

enum OrgMemberRole {
  OWNER
  ADMIN
  PLAYER
}

model GroupMember {
  id       String    @id @default(uuid())
  userId   String
  groupId  String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

enum GroupRole {
  ADMIN
  MEMBER
}

model PoolContribution {
  id         String    @id @default(uuid())
  userId     String
  groupId    String
  amount     Int
  paid       Boolean   @default(false)
  paidAt     DateTime?
  refundedAt DateTime?

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

/// PoolPaymentTracking is the Phase-2 (MANUAL_POOL) registro of who the
/// organizer marked as "paid". This table records intent, NOT actual money
/// movement — the organizer collects entry fees by their own means
/// (transfer/cash/MP-of-organizer) and uses this table as a shared dashboard.
/// ArmaTuProde never custodies the pool money.
/// PremiumMembership = jugador que pagó por features extra dentro de un torneo.
/// Modelo B2C "Spotify-like": el jugador desbloquea premium voluntariamente.
/// NO es apuesta. NO depende del resultado deportivo. Es paywall de software.
model PremiumMembership {
  id              String    @id @default(uuid())
  userId          String
  tournamentId    String
  paidAt          DateTime  @default(now())
  validUntil      DateTime
  amountUsd       Int
  paymentOrderId  String?
  source          String    @default("mp")

  user       User       @relation(fields: [userId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([userId, tournamentId])
  @@index([userId])
  @@index([validUntil])
}

model PoolPaymentTracking {
  id          String    @id @default(uuid())
  groupId     String
  userId      String
  paid        Boolean   @default(false)
  paidAt      DateTime?
  markedById  String
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  group Group @relation(fields: [groupId], references: [id])

  @@unique([groupId, userId])
  @@index([groupId])
}

model XpEvent {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  matchId   String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  match Match? @relation(fields: [matchId], references: [id])

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  icon      String   @default("🔔")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

model ActivityEvent {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  type      String
  text      String
  icon      String
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt])
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserBooster {
  id       String @id @default(uuid())
  userId   String
  type     String
  quantity Int    @default(1)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model CoinTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// --- Wallet & Economy ---

enum WalletLotSource {
  PREDICTION
  WINNER
  EXACT
  STREAK
  MATCHDAY
  REFERRAL
  PURCHASE
  MIGRATION
  ADMIN
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  EXPIRY
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  lots         WalletLot[]
  transactions WalletTransaction[]
}

model WalletLot {
  id        String          @id @default(uuid())
  walletId  String
  source    WalletLotSource
  amount    Int
  remaining Int
  expiresAt DateTime
  createdAt DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, expiresAt])
}

model WalletTransaction {
  id             String                @id @default(uuid())
  walletId       String
  type           WalletTransactionType
  amount         Int
  source         String?
  reason         String
  idempotencyKey String?               @unique
  metadata       Json?
  createdAt      DateTime              @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
}

model BoosterActivation {
  id        String   @id @default(uuid())
  userId    String
  matchId   String
  type      String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}

// --- Group Chat ---

enum ChatMessageType {
  TEXT
  STICKER
  SYSTEM
}

model ChatMessage {
  id         String          @id @default(uuid())
  groupId    String
  userId     String?
  type       ChatMessageType @default(TEXT)
  content    String
  stickerKey String?
  deleted    Boolean         @default(false)
  createdAt  DateTime        @default(now())

  group     Group           @relation(fields: [groupId], references: [id])
  user      User?           @relation(fields: [userId], references: [id])
  reactions ChatReaction[]

  @@index([groupId, createdAt])
}

model ChatReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChatMute {
  id         String   @id @default(uuid())
  groupId    String
  userId     String
  mutedUntil DateTime
  createdAt  DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

// --- Payments ---

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CHARGEBACK
}

enum PaymentType {
  COIN_PACK
  POOL_ENTRY
  GROUP_ACTIVATION
  PLAYER_PREMIUM
}

model PaymentOrder {
  id           String        @id @default(uuid())
  userId       String
  type         PaymentType
  status       PaymentStatus @default(PENDING)
  amount       Int
  description  String
  metadata     Json?
  externalId   String?       @unique
  preferenceId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// --- Tournament data ---

model Team {
  id            String  @id @default(uuid())
  tournamentId  String
  code          String
  name          String
  country       String
  flag          String  @default("")
  confederation String?
  groupCode     String?
  groupSlot     Int?
  isPlaceholder Boolean @default(false)

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, code])
  @@index([tournamentId, groupCode])
}

// --- Admin audit log ---

model AdminAuditLog {
  id        String   @id @default(uuid())
  action    String
  adminHash String?
  ip        String?
  userAgent String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([createdAt])
}
