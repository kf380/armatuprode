{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-coins",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/matches/check-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/sync-results",
      "schedule": "*/2 * * * *"
    }
  ]
}
